{
  "name": "seattle-map",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "A time-space cartogram of Seattle, where on-screen distance follows travel time instead of geography.",
  "scripts": {
    "grid": "npx -y tsx scripts/generateGrid.ts",
    "osm": "npx -y tsx scripts/fetchOsm.ts",
    "traffic": "npx -y tsx scripts/fetchTraffic.ts",
    "matrix": "npx -y tsx scripts/fetchMatrix.ts",
    "embed": "npx -y tsx scripts/embed.ts",
    "viewer": "npx -y tsx scripts/buildViewer.ts",
    "pipeline": "npx -y tsx scripts/pipeline.ts",
    "typecheck": "tsc --noEmit",
    "water": "npx -y tsx scripts/fetchWater.ts",
    "sharecard": "npx -y tsx scripts/buildShareCard.ts"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5.7"
  }
}
